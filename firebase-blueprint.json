{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the application." }
      },
      "required": ["uid", "email"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A recurring subscription tracked by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the subscription." },
        "userId": { "type": "string", "description": "The UID of the user who owns this subscription." },
        "name": { "type": "string", "description": "Name of the subscription service (e.g., Netflix)." },
        "amount": { "type": "number", "description": "The cost of the subscription." },
        "currency": { "type": "string", "description": "Currency code (e.g., USD)." },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"], "description": "How often the subscription is billed." },
        "nextBillingDate": { "type": "string", "format": "date-time", "description": "The date of the next billing." },
        "category": { "type": "string", "description": "Category of the subscription (e.g., Entertainment)." },
        "icon": { "type": "string", "description": "Icon name or identifier." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the subscription was added." }
      },
      "required": ["userId", "name", "amount", "billingCycle"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Individual subscription documents."
    }
  }
}
